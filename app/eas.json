{
  "cli": {
    "version": ">= 18.4.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_APP_ENV": "preview",
        "EXPO_PUBLIC_REVIEW_PHOTO_BUCKET_PREVIEW": "reviewsPics"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "env": {
        "EXPO_PUBLIC_APP_ENV": "production",
        "EXPO_PUBLIC_REVIEW_PHOTO_BUCKET_PROD": "Roicseviews"
      },
      "autoIncrement": true
    }
  },
  "submit": {
    "production": {}
  }
}