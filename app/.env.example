# Supabase project URL
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase public anon key
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Backend base URL
# Local backend from this repo runs on port 3000.
EXPO_PUBLIC_API_URL=http://localhost:3000

# Service role key used by current app admin client.
# Keep this value private and move service-role operations to backend before release.
EXPO_PUBLIC_SUPABASE_SERVICE_KEY=your-supabase-service-role-key


