# App environment: development or production
EXPO_PUBLIC_APP_ENV=development

# Shared Supabase config used by default
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Backend base URL used by default
EXPO_PUBLIC_API_URL=http://localhost:3000

# Optional environment-specific overrides:
# EXPO_PUBLIC_SUPABASE_URL_DEV=...
# EXPO_PUBLIC_SUPABASE_ANON_KEY_DEV=...
# EXPO_PUBLIC_SUPABASE_URL_STAGING=...
# EXPO_PUBLIC_SUPABASE_ANON_KEY_STAGING=...
# EXPO_PUBLIC_SUPABASE_URL_PROD=...
# EXPO_PUBLIC_SUPABASE_ANON_KEY_PROD=...
# EXPO_PUBLIC_API_URL_DEV=...
# EXPO_PUBLIC_API_URL_STAGING=...
# EXPO_PUBLIC_API_URL_PROD=...

# Do not add SUPABASE service-role keys in app env files.
# EXPO_PUBLIC_* values are bundled into the client app.

