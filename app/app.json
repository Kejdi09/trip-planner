{
  "expo": {
    "name": "TripSync",
    "slug": "app",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "tripsync",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.tripsync.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "predictiveBackGestureEnabled": false,
      "package": "com.tripsync.app"
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0b94bd5e-ebd3-44bd-a6bf-8154249babc0"
      }
    },
    "owner": "musabobito"
  }
}
