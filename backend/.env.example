PORT=3000

# Backend environment: development or production
APP_ENV=development

# Shared Supabase credentials (used by default)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# Optional environment-specific overrides:
# SUPABASE_URL_DEV=https://your-dev-project-ref.supabase.co
# SUPABASE_SERVICE_KEY_DEV=your-dev-supabase-service-role-key
# SUPABASE_URL_STAGING=https://your-preview-project-ref.supabase.co
# SUPABASE_SERVICE_KEY_STAGING=your-preview-supabase-service-role-key
# SUPABASE_URL_PROD=https://your-prod-project-ref.supabase.co
# SUPABASE_SERVICE_KEY_PROD=your-prod-supabase-service-role-key

# Backend only. Never expose service-role keys to frontend or EXPO_PUBLIC_* vars.
