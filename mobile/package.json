{
  "name": "trip-planner-mobile",
  "version": "1.0.0",
  "description": "Expo + React Native mobile application for trip-planner",
  "engines": {
    "node": ">=20"
  },
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "build": "expo export",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "test": "jest --coverage"
  },
  "dependencies": {
    "expo": "~50.0.6",
    "expo-status-bar": "~1.11.1",
    "react": "18.2.0",
    "react-native": "0.73.4",
    "react-native-web": "~0.19.6",
"react-dom": "18.2.0",
"@expo/metro-runtime": "~3.1.3"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@testing-library/react-native": "^12.4.3",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.33.2",
    "jest": "^29.7.0",
    "jest-expo": "~50.0.1",
    "react-test-renderer": "18.2.0"
  },
  "jest": {
    "preset": "jest-expo",
    "collectCoverageFrom": [
      "**/*.{js,jsx,ts,tsx}",
      "!**/node_modules/**",
      "!**/coverage/**"
    ]
  }
}
